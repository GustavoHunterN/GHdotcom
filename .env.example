# Copy this file to .env and fill in values (never commit .env).

# GitHub token (https://github.com/settings/tokens)
GITHUB_TOKEN=

# Optional: GitHub login for GET /repos/{owner}/{repo}. If unset, resolved via GET /user.
# GITHUB_OWNER=

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=GH

# Web showcase: how many repos to load on GET / (integer), or "all" to use HOME_REPO_MAX
# HOME_REPO_LIMIT=100
# HOME_REPO_MAX=100
